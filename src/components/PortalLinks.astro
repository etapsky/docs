---
/**
 * PortalLinks — Starlight SocialIcons override
 *
 * Default: "Portal →" amber badge-style button with shimmer.
 * Auth-aware: if logged in via cookie session, upgrades to avatar + "Dashboard".
 *
 * Requirements for auth-aware mode:
 *   - API CORS allows https://docs.etapsky.com
 *   - Auth cookie set on .etapsky.com domain
 */
import Default from '@astrojs/starlight/components/SocialIcons.astro';
---

<div class="etk-portal-links" role="group" aria-label="Etapsky Portal">
  <a
    id="etk-portal-btn"
    href="https://portal.etapsky.com"
    class="etk-plink"
    aria-label="Open Etapsky Portal"
  >
    <span id="etk-portal-inner" class="etk-plink-inner">
      <span>Portal</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
      </svg>
    </span>
  </a>
  <span class="etk-plink-sep" aria-hidden="true"></span>
</div>
<Default><slot /></Default>

<style>
  .etk-portal-links {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .etk-plink-sep {
    display: block;
    width: 1px;
    height: 16px;
    background: currentColor;
    opacity: 0.16;
    border-radius: 1px;
    margin-inline: 4px;
    flex-shrink: 0;
  }

  /* ── Badge button — amber, mirrors .etk-docs style ───────────── */
  .etk-plink {
    display: inline-flex;
    align-items: center;
    text-decoration: none;

    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.2;

    padding: 0.28em 0.65em 0.3em;
    border-radius: 9999px;
    border: 1.5px solid #fbbf24;
    color: #fef3c7 !important;
    background: linear-gradient(145deg, rgba(251, 191, 36, 0.35) 0%, rgba(245, 158, 11, 0.22) 100%);
    box-shadow:
      0 0 0 1px rgba(251, 191, 36, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);

    position: relative;
    overflow: hidden;

    transition:
      border-color 200ms ease,
      box-shadow   200ms ease,
      background   200ms ease,
      color        200ms ease;
  }

  /* ── Shimmer sweep ───────────────────────────────────────────── */
  .etk-plink::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -75%;
    width: 45%;
    height: 200%;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(255, 255, 255, 0.28) 50%,
      transparent 100%
    );
    transform: skewX(-18deg);
    animation: etk-shimmer 3s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes etk-shimmer {
    0%   { left: -75%; opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { left: 135%; opacity: 0; }
  }

  /* ── Hover ───────────────────────────────────────────────────── */
  .etk-plink:hover {
    color: #fef9c3 !important;
    border-color: #fde68a;
    background: linear-gradient(145deg, rgba(252, 211, 77, 0.45) 0%, rgba(251, 191, 36, 0.32) 100%);
    box-shadow:
      0 0 0 1px rgba(252, 211, 77, 0.45),
      0 0 14px rgba(251, 191, 36, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.16);
  }

  /* ── Light mode ──────────────────────────────────────────────── */
  :root[data-theme='light'] .etk-plink {
    color: #92400e !important;
    border-color: #f59e0b;
    background: linear-gradient(180deg, #fffbeb 0%, #fef3c7 100%);
    box-shadow:
      0 0 0 1px rgba(245, 158, 11, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  :root[data-theme='light'] .etk-plink::after {
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(255, 255, 255, 0.55) 50%,
      transparent 100%
    );
  }

  :root[data-theme='light'] .etk-plink:hover {
    color: #78350f !important;
    border-color: #d97706;
    background: linear-gradient(180deg, #fef9c3 0%, #fde68a 100%);
    box-shadow:
      0 0 0 1px rgba(245, 158, 11, 0.35),
      0 0 12px rgba(251, 191, 36, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 1);
  }

  /* ── Avatar (shown when logged in) ───────────────────────────── */
  .etk-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 15px;
    height: 15px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.28);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0;
    flex-shrink: 0;
  }

  .etk-plink-inner {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    position: relative;
    z-index: 1;
  }

  /* Hide on small screens */
  @media (max-width: 50rem) {
    .etk-portal-links {
      display: none;
    }
  }
</style>

<script>
  interface MeResponse {
    user?: { name?: string; email?: string }
    name?: string
    email?: string
  }

  async function upgradePortalBtn() {
    try {
      const res = await fetch('https://api.etapsky.com/v1/auth/me', {
        credentials: 'include',
      })
      if (!res.ok) return

      const data: MeResponse = await res.json()
      const name = data.user?.name ?? data.name ?? ''

      const btn = document.getElementById('etk-portal-btn')
      const inner = document.getElementById('etk-portal-inner')
      if (!btn || !inner) return

      btn.setAttribute('href', 'https://portal.etapsky.com/dashboard')
      btn.setAttribute('aria-label', 'Go to Dashboard')

      const initials = name
        .split(' ')
        .map((w: string) => w[0] ?? '')
        .join('')
        .slice(0, 2)
        .toUpperCase() || '?'

      inner.innerHTML = `<span class="etk-avatar">${initials}</span><span>Dashboard</span>`
    } catch {
      // Not logged in or API unreachable — keep default "Portal" button
    }
  }

  upgradePortalBtn()
</script>
