---
/**
 * SiteTitle — Etapsky Docs header identity
 *
 * Logo + thin separator + "docs" monospace chip (tinted bg + purple border).
 */
---

<a
	href="/"
	class="etk-site-title"
	aria-label="Etapsky Docs — Home"
	transition:persist="etk-site-title"
	transition:animate="none"
>
  <!-- Light mode logo -->
  <img
    class="etk-logo etk-logo--light"
    src="/etapsky_horizontal_logo.svg"
    alt="Etapsky"
    height="40"
    loading="eager"
    decoding="async"
  />
  <!-- Dark mode logo -->
  <img
    class="etk-logo etk-logo--dark"
    src="/etapsky_horizontal_logo.svg"
    alt="Etapsky"
    height="40"
    loading="eager"
    decoding="async"
  />

  <span class="etk-sep" aria-hidden="true"></span>
  <span class="etk-docs" aria-hidden="true">docs</span>
</a>

<style>
  /* ── Container ──────────────────────────────────────────────── */
  .etk-site-title {
    display: inline-flex;
    align-items: center;
    gap: 0;
    text-decoration: none;
    color: inherit;
    user-select: none;
    -webkit-user-select: none;
  }

  /* ── Logo — theme switching ──────────────────────────────────── */
  .etk-logo {
    height: 40px;
    width: auto;
    max-height: 40px;
    display: block;
    flex-shrink: 0;
    object-fit: contain;
    object-position: left center;
  }

  /* Default (dark): dark logo visible, inverted to #EADDBF */
  :root:not([data-theme='light']) .etk-logo--dark  { display: block; filter: invert(1); }
  :root:not([data-theme='light']) .etk-logo--light { display: none;  }

  /* Light mode: light logo visible, default #152240 */
  :root[data-theme='light'] .etk-logo--dark  { display: none;  }
  :root[data-theme='light'] .etk-logo--light { display: block; }

  /* ── Divider ─────────────────────────────────────────────────── */
  .etk-sep {
    display: block;
    width: 1px;
    height: 16px;
    background: currentColor;
    opacity: 0.16;
    margin: 0 12px;
    flex-shrink: 0;
    border-radius: 1px;
  }

  /* ── "docs" label — chip: tinted bg + chroma border ─────────────── */
  .etk-docs {
    font-family: 'DM Mono', ui-monospace, 'SF Mono', Menlo, 'Cascadia Code', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.2;
    position: relative;
    top: 0.5px;

    padding: 0.28em 0.55em 0.3em;
    border-radius: 6px;
    border: 1.5px solid #a78bfa;
    color: #ede9fe;
    background:
      linear-gradient(145deg, rgba(124, 58, 237, 0.35) 0%, rgba(91, 33, 182, 0.22) 100%);
    box-shadow:
      0 0 0 1px rgba(167, 139, 250, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);

    -webkit-text-fill-color: unset;
    background-clip: border-box;
    transition:
      border-color var(--etk-theme-transition, 150ms ease),
      box-shadow var(--etk-theme-transition, 150ms ease),
      background var(--etk-theme-transition, 150ms ease),
      color var(--etk-theme-transition, 150ms ease);
  }

  :root[data-theme='light'] .etk-docs {
    color: #5b21b6;
    border-color: #7c3aed;
    background: linear-gradient(180deg, #f5f3ff 0%, #ede9fe 100%);
    box-shadow:
      0 0 0 1px rgba(124, 58, 237, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
  }

  /* ── Hover: label + sep ─────────────────────────────────────── */
  .etk-site-title:hover .etk-sep {
    opacity: 0.28;
    transition: opacity var(--etk-theme-transition, 150ms ease);
  }

  .etk-site-title:hover .etk-docs {
    border-color: #c4b5fd;
    color: #f5f3ff;
    background:
      linear-gradient(145deg, rgba(139, 92, 246, 0.45) 0%, rgba(109, 40, 217, 0.28) 100%);
    box-shadow:
      0 0 0 1px rgba(196, 181, 253, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }

  :root[data-theme='light'] .etk-site-title:hover .etk-docs {
    color: #4c1d95;
    border-color: #6d28d9;
    background: linear-gradient(180deg, #faf5ff 0%, #e9d5ff 100%);
    box-shadow:
      0 0 0 1px rgba(124, 58, 237, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 1);
  }
</style>
